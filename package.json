{
  "name": "nest-identity",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "pnpm test:all",
    "test:watch": "jest --watch",
    "test:cov": "pnpm test:all:cov",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:identity": "jest --config apps/identity/jest-unit.json",
    "test:identity:cov": "jest --config apps/identity/jest-unit.json --coverage",
    "test:payment": "jest --config apps/payment/jest-unit.json",
    "test:payment:cov": "jest --config apps/payment/jest-unit.json --coverage",
    "test:chat": "jest --config apps/chat-service/jest-unit.json",
    "test:chat:cov": "jest --config apps/chat-service/jest-unit.json --coverage",
    "test:e2e:identity": "jest --config apps/identity/jest-e2e.json --runInBand --forceExit --detectOpenHandles",
    "test:e2e:payment": "jest --config apps/payment/jest-e2e.json --runInBand --forceExit --detectOpenHandles",
    "test:all": "pnpm test:identity && pnpm test:payment && pnpm test:chat",
    "test:all:cov": "pnpm test:identity:cov && pnpm test:payment:cov && pnpm test:chat:cov",
    "migration:generate": "NODE_ENV=test ts-node libs/common/src/databases/typeorm/migrations/generate.migration.ts",
    "sql:generate": "NODE_ENV=migration ts-node libs/common/src/databases/typeorm/migrations/generate.sql.ts"
  },
  "dependencies": {
    "@eslint/js": "^9.18.0",
    "@langchain/core": "^0.3.3",
    "@langchain/groq": "^0.1.2",
    "@langchain/mongodb": "^0.1.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bull": "^10.2.3",
    "@nestjs/common": "^9.4.3",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^9.0.0",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/microservices": "^9.4.3",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^9.0.0",
    "@nestjs/platform-socket.io": "^9.4.3",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^9.4.3",
    "@socket.io/redis-adapter": "^8.3.0",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "axios": "^1.11.0",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.2.1",
    "flatbuffers": "^25.9.23",
    "groq-sdk": "^0.7.0",
    "ioredis": "^5.4.2",
    "joi-password-complexity": "^5.2.0",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^0.3.2",
    "mongodb": "^6.9.0",
    "mysql2": "3.11.3",
    "nestjs-cls": "^4.4.1",
    "passport-headerapikey": "^1.2.2",
    "passport-http": "^0.3.0",
    "passport-jwt": "^4.0.1",
    "prom-client": "^15.1.3",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^3.0.2",
    "rxjs": "^7.2.0",
    "shelljs": "^0.10.0",
    "socket.io": "^4.8.1",
    "tunnel-ssh": "^5.2.0",
    "typeorm": "^0.3.20",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^9.0.0",
    "@nestjs/schematics": "^9.0.0",
    "@nestjs/testing": "^9.0.0",
    "@types/express": "^4.17.13",
    "@types/jest": "28.1.8",
    "@types/node": "^16.0.0",
    "@types/socket.io": "^3.0.2",
    "@types/supertest": "^2.0.11",
    "eslint": "^9.8.0",
    "jest": "28.1.3",
    "prettier": "^2.3.2",
    "socket.io-client": "^4.8.3",
    "source-map-support": "^0.5.20",
    "supertest": "^6.1.3",
    "ts-jest": "28.0.8",
    "ts-loader": "^9.2.3",
    "ts-node": "^10.0.0",
    "tsconfig-paths": "4.1.0",
    "typescript": "^4.7.4",
    "typescript-eslint": "^8.19.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
