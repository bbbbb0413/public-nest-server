{
  "name": "nest-identity",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build && nest build rpc",
    "build:identity": "nest build identity && nest build rpc",
    "build:payment": "nest build payment && nest build rpc",
    "build:chat-service": "nest build chat-service && nest build rpc",
    "build:gateway": "nest build gateway && nest build rpc",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "pnpm test:all",
    "test:watch": "jest --watch",
    "test:cov": "pnpm test:all:cov",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:identity": "jest --config apps/identity/jest-unit.json",
    "test:identity:cov": "jest --config apps/identity/jest-unit.json --coverage",
    "test:payment": "jest --config apps/payment/jest-unit.json",
    "test:payment:cov": "jest --config apps/payment/jest-unit.json --coverage",
    "test:chat": "jest --config apps/chat-service/jest-unit.json",
    "test:chat:cov": "jest --config apps/chat-service/jest-unit.json --coverage",
    "test:gateway": "jest --config apps/gateway/jest-unit.json",
    "test:gateway:cov": "jest --config apps/gateway/jest-unit.json --coverage",
    "test:e2e:identity": "jest --config apps/identity/jest-e2e.json --runInBand --forceExit --detectOpenHandles",
    "test:e2e:payment": "jest --config apps/payment/jest-e2e.json --runInBand --forceExit --detectOpenHandles",
    "test:e2e:gateway": "jest --config apps/gateway/jest-e2e.json --runInBand --forceExit --detectOpenHandles",
    "test:e2e:all": "pnpm test:e2e:identity && pnpm test:e2e:payment && pnpm test:e2e:gateway",
    "test:all": "pnpm test:identity && pnpm test:payment && pnpm test:chat && pnpm test:gateway",
    "test:all:cov": "pnpm test:identity:cov && pnpm test:payment:cov && pnpm test:chat:cov && pnpm test:gateway:cov",
    "migration:generate": "NODE_ENV=test ts-node libs/common/src/databases/typeorm/migrations/generate.migration.ts",
    "sql:generate": "NODE_ENV=migration ts-node libs/common/src/databases/typeorm/migrations/generate.sql.ts"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@langchain/core": "^1.1.48",
    "@langchain/groq": "^1.2.1",
    "@langchain/mongodb": "^1.2.1",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.24",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/platform-socket.io": "^11.1.24",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/typeorm": "^11.0.1",
    "@nestjs/websockets": "^11.1.24",
    "@socket.io/redis-adapter": "^8.3.0",
    "@willsoto/nestjs-prometheus": "^6.1.0",
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "flatbuffers": "^25.9.23",
    "groq-sdk": "^1.2.1",
    "ioredis": "^5.11.0",
    "joi-password-complexity": "^5.2.0",
    "jsonwebtoken": "^9.0.3",
    "langchain": "^1.4.4",
    "mongodb": "^7.2.0",
    "mysql2": "3.22.4",
    "nestjs-cls": "^6.2.1",
    "passport-headerapikey": "^1.2.2",
    "passport-http": "^0.3.0",
    "passport-jwt": "^4.0.1",
    "prom-client": "^15.1.3",
    "redis": "^6.0.0",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.1.3",
    "rxjs": "^7.8.2",
    "shelljs": "^0.10.0",
    "socket.io": "^4.8.3",
    "tunnel-ssh": "^5.2.0",
    "typeorm": "^1.0.0",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.24",
    "@types/express": "^5.0.6",
    "@types/jest": "29.5.14",
    "@types/node": "^25.9.1",
    "@types/socket.io": "^3.0.2",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.4.1",
    "jest": "29.7.0",
    "prettier": "^3.8.3",
    "socket.io-client": "^4.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "29.4.11",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "ts-proto": "^2.11.8",
    "tsconfig-paths": "4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
