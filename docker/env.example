# =============================================
# Docker Compose 환경변수 예시 파일
# 이 파일을 복사해 docker/.env 로 만든 뒤 실제 값을 채워넣으세요.
# docker/.env 는 .gitignore 에 추가하세요.
# =============================================

# MySQL Root
MYSQL_ROOT_PASSWORD=your_mysql_root_password

# DB User (init SQL에서 생성되는 계정)
DB_USER=admin
DB_USER_PW=your_db_user_password

# MongoDB
MONGO_ROOT_USERNAME=mongo
MONGO_ROOT_PASSWORD=your_mongo_password

# JWT Secrets
ACCESS_TOKEN_SECRET=your_jwt_access_secret_min_32chars
REFRESH_TOKEN_SECRET=your_jwt_refresh_secret_min_32chars

# External API Keys
GROQ_API_KEY=your_groq_api_key

# ngrok (https://dashboard.ngrok.com 에서 발급)
NGROK_AUTHTOKEN=your_ngrok_authtoken
