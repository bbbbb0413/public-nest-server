{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../../",
  "setupFiles": ["<rootDir>/test-support/jest-setup.js"],
  "testMatch": [
    "<rootDir>/apps/payment/src/**/*.spec.ts",
    "<rootDir>/libs/auth/src/**/*.spec.ts"
  ],
  "transform": {
    "^.+\\.ts$": "ts-jest"
  },
  "collectCoverageFrom": [
    "apps/payment/src/**/*.ts",
    "libs/auth/src/**/*.ts",
    "!**/*.module.ts",
    "!**/index.ts",
    "!**/*.dto.ts",
    "!**/*.entity.ts"
  ],
  "coverageDirectory": "coverage/payment",
  "testEnvironment": "node",
  "moduleNameMapper": {
    "^@libs/shared-kernel(|/.*)$": "<rootDir>/libs/shared-kernel/src/$1",
    "^@libs/common(|/.*)$": "<rootDir>/libs/common/src/$1",
    "^@libs/dao(|/.*)$": "<rootDir>/libs/dao/src/$1",
    "^@libs/auth(|/.*)$": "<rootDir>/libs/auth/src/$1",
    "^@extension/(.*)$": "<rootDir>/libs/common/src/extension/$1"
  }
}
