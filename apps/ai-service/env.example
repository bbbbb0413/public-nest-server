# AI Service 환경변수
AI_SERVICE_PORT=3004

# LLM 프로바이더 선택 (claude | openai | gemini | groq)
LLM_PROVIDER=claude

# Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI (LLM + 임베딩 모두 사용)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# Google Gemini
GOOGLE_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-2.0-flash

# Groq
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (로컬 LLM — API 키 불필요)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_EMBEDDING_MODEL=bge-m3

# MongoDB (벡터 저장소 + 문서 메타데이터)
MONGODB_VECTOR_URI=mongodb+srv://user:password@cluster.mongodb.net/
MONGODB_DB_NAME=ai_service
